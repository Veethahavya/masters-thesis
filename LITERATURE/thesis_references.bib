@article{Schlotzhauer1999,
abstract = {In this paper concerned with soil water dynamics in a managed cutover peat field, the microscale hydrological processes and parameters governing water flow and storage through variably saturated peat are investigated. An open water ditch-reservoir enhanced wetting of adjacent cutover peat, maintaining the water table depth above 43 cm during the summer, surface soil moisture above 45%, and water tension in the surface layer above -45 mbar. Desaturation of pores was noted in the -2 and -10 cm depths, but at -30 and -50 cm a decrease in moisture content of several percent was associated with compression of the peat as the water table dropped. Air entry occurred only at pressures below -15 mbar. Seasonal subsidence resulted in cumulative vertical displacement in excess of 10 cm during the study period. Typical settlements in the peat ranged between 11 and 23% of the lowering of the water table. Considerable hysteresis was observed, and vertical displacement was 5 times greater in response to water loss, compared to rewetting. The specific storage (S(s)) in the 180 cm thick deposit averaged 9.4 x 10-4 cm-1 during drying periods but averaged only 2.6 x 10-4 cm-1 on rewetting. S(s) was more important than specific yield (S(y)) in the overall aquifer storativity. Transient hydraulic properties resulted from the shifting soil structure. The increase in peat bulk density caused by drying increased the water retention capacity and decreased hydraulic conductivity. Mean saturated hydraulic conductivity was 15 cm d-1 and decreased 2 orders of magnitude as the degree of saturation dropped from 1 to 0.4. The horizontal/vertical anisotropy ratio was 4. The changing surface elevation in response to seasonal subsidence had a profound influence on the nature of the storage changes and hydraulic parameters of the peat soil.},
author = {Schlotzhauer, Susanne M. and Price, Jonathan S.},
doi = {10.1029/1999WR900126},
file = {:C\:/Users/kup/Downloads/Schlotzhauer_Price_WRR_1999_03.pdf:pdf},
issn = {00431397},
journal = {Water Resources Research},
number = {12},
pages = {3675--3683},
title = {{Soil water flow dynamics in a managed cutover peat field, Quebec: Field and laboratory investigations}},
volume = {35},
year = {1999}
}

@article{Shestakov2002,
abstract = {This study summarizes published data and field experiments to validate a semi-empirical relation of specific storage and compressibility parameters of granular water-bearing rocks to their location depth within the hundreds of meters' range. Using the Terzaghi compression equation and a precondition of geostatic stress distribution a hyperbolic equation relating specific storage aquifer with depth from ground surface is obtained in the form Ss = A/Z5+Z0. Comparison of specific storage calculated by the obtained equation with field data shows it to be in good agreement for sands, with the parameter A ranging from 6x10-4 to 3x10-3 and with a typical value of 10-3. This study is associated with hydrogeomechanics, a branch of hydrogeology that the author and V.A. Mironenko have formulated and developed in close collaboration.},
author = {Shestakov, V. M.},
doi = {10.1007/s00254-001-0481-z},
file = {:C\:/Users/kup/Downloads/Shestakov2002_Article_DevelopmentOfRelationshipBetwe.pdf:pdf},
issn = {09430105},
journal = {Environmental Geology},
keywords = {Compressibility,Field experiments,Granular materials,Specific storage},
number = {2-3},
pages = {127--129},
title = {{Development of relationship between specific storage and depth of sandy and clay formations}},
volume = {42},
year = {2002}
}

@article{Lu2015,
abstract = {This chapter focuses on identification of existing conventional site investigation data that are valuable to forensic evaluation. Forensic information may be derived from various types of the site investigation data, including history of handling and use of chemicals of potential concern (COPCs) at a site, geological and hydrogeological data related to contaminant migration pathways and transport and fate, contaminant chemical data from compliance driven laboratory analyses, high-resolution site characterization data, such as LIF and MIP, and postrelease contaminant concentration pattern changes occurring both naturally and due to remediation activities. The systematic approach and examples presented in this chapter can be used to guide preliminary data collection process. In some cases, the forensic information derived from site investigation data may be sufficient to resolve source issues. However, in other cases data gaps are identified during the process so that a more focused, cost-effective approach can be developed for an environmental forensics investigation.},
author = {Lu, Jun},
doi = {10.1016/B978-0-12-404696-2.00006-0},
file = {:C\:/Users/kup/Downloads/9319f466-5df3-47bc-bf71-cf62314983de.pdf:pdf},
isbn = {9780124046962},
journal = {Introduction to Environmental Forensics: Third Edition},
keywords = {Analytical data mining,Contaminant migration,Environmental forensic evaluation,High resolution site characterization tools,Natural attenuation,Remediation,Site investigation data,Source identification},
number = {5},
pages = {149--164},
title = {{Identification of Forensic Information from Existing Conventional Site-Investigation Data}},
year = {2015}
}

